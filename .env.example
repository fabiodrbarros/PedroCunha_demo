# ─────────────────────────────────────────────────────────────
#  Pedro Cunha Carpintaria — Environment
#  Copy to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# Database
# Development (SQLite):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL) — switch provider in prisma/schema.prisma to "postgresql":
# DATABASE_URL="postgresql://user:password@host:5432/pedrocunha?schema=public"

# Public site URL (used for canonical URLs, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Admin authentication ──────────────────────────────────────
# Username for the /admin area.
ADMIN_USERNAME="admin"

# bcrypt hash of the admin password.
# Generate one with:  npm run hash -- "your-strong-password"
# IMPORTANT: escape every "$" as "\$" so Next's env loader keeps the hash intact.
# `npm run hash` already prints a ready-to-paste, escaped line.
ADMIN_PASSWORD_HASH="\$2a\$12\$REPLACE_WITH_A_REAL_BCRYPT_HASH_VALUE_000000000000000"

# Secret used to sign the httpOnly session cookie (JWT).
# Generate one with:  openssl rand -base64 48
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"
